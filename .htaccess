<IfModule mod_rewrite.c>
    RewriteEngine On

    # Route everything through the Laravel public directory
    RewriteCond %{REQUEST_URI} !^/allied-business/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Deny direct access to sensitive files if rewrite is unavailable
<FilesMatch "^\.env|composer\.(json|lock)$">
    Require all denied
</FilesMatch>
